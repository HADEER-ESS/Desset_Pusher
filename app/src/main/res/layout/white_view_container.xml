<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/white_box">

    <TextView
        android:id="@+id/dessert_sold_txt"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/desserts_sold"
        android:textSize="18sp"
        android:layout_marginStart="36dp"
        android:layout_marginTop="24dp"
        app:layout_constraintEnd_toStartOf="@+id/dessert_total_count"
        app:layout_constraintHorizontal_bias="0.5"
        app:layout_constraintHorizontal_chainStyle="spread_inside"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/dessert_total_count"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textSize="18sp"
        android:layout_marginTop="24dp"
        android:layout_marginEnd="36dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.5"
        app:layout_constraintStart_toEndOf="@+id/dessert_sold_txt"
        app:layout_constraintTop_toTopOf="parent"
        tools:text="0" />

    <TextView
        android:id="@+id/price_total_value"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toBottomOf="@id/dessert_total_count"
        app:layout_constraintEnd_toEndOf="@id/dessert_total_count"
        app:layout_constraintStart_toStartOf="@id/dessert_total_count"
        app:layout_constraintBottom_toBottomOf="parent"
        tools:text="$ 0.0"
        android:layout_marginBottom="24dp"
        android:textSize="22sp"
        android:textColor="@color/green"
        android:layout_marginTop="18dp"
        />
</androidx.constraintlayout.widget.ConstraintLayout>